generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id         String   @id @default(uuid())
  name       String
  email      String
  subject    String
  message    String
  status     String   @default("Pending")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}